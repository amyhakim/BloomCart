{
  "manifest_version": 3,
  "name": "BloomCart Cart Reader",
  "version": "0.1.0",
  "description": "Reads cart pages and extracts product information for BloomCart.",
  "key": "",
  "permissions": ["storage", "tabs", "scripting", "notifications"],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.walmart.com/*",
    "https://*.target.com/*",
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*"
  ],
  "action": {
    "default_title": "Read Cart"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://*.walmart.com/*",
        "https://*.target.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:5173/*",
      "http://127.0.0.1:5173/*"
    ]
  }
}
